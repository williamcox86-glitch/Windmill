{
  "format_version": "1.8.0",
  "animations": {
    "animation.windmill.spin": {
      "timeline": {
        "0.0": [
          "/rotate @s 0 0 0"
        ],
        "0.5": [
          "/rotate @s 45 0 0"
        ],
        "1.0": [
          "/rotate @s 90 0 0"
        ],
        "1.5": [
          "/rotate @s 135 0 0"
        ],
        "2.0": [
          "/rotate @s 180 0 0"
        ],
        "2.5": [
          "/rotate @s 225 0 0"
        ],
        "3.0": [
          "/rotate @s 270 0 0"
        ],
        "3.5": [
          "/rotate @s 315 0 0"
        ]
      },
      "loop": true
    }
  },
  "animation_controllers": {
    "animation.windmill.spin_controller": {
      "states": {
        "default": {
          "animations": [
            "animation.windmill.spin"
          ]
        }
      }
    }
  }
}
